DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/Circles
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Supabase (Project Settings → Database → Connection string → URI, Session mode for Render):
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# DATABASE_SSL=require

# Comma-separated frontend origins (Vercel production URL + preview if needed).
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-git-main-you.vercel.app

# Google Sign-In (OAuth 2.0 Web client). Same Client ID in web/.env as VITE_GOOGLE_CLIENT_ID.
# In Google Cloud Console: APIs & Services → Credentials → OAuth client (Web application).
# Authorized JavaScript origins: http://localhost:5173 http://127.0.0.1:5173
# Production: add https://your-app.vercel.app
GOOGLE_OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

